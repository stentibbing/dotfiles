# set $power exec nu $sway_config/scripts/power_menu.nu 
set $internal_screen 'eDP-1'
set $usb-c-1 'DP-1'
set $usb-c-2 'DP-2'

# monitors
include ~/.config/sway/monitors

# displays @ home
# output 'AU Optronics 0x243D Unknown' pos 0 0 res 1920x1080 scale 1.5
# output 'LG Electronics LG HDR 4K 0x0004AD6B' pos 1920 0 res 3840x2160 scale 2

# displays @ work
output 'AU Optronics 0x243D Unknown' pos 5120 0 res 1920x1080 scale 1.5
output 'Dell Inc. DELL P3223DE HZYTL04' pos 0 0 res 2560x1440 scale 1.25
output 'Dell Inc. DELL P3223DE HW31M04' pos 2560 0 res 2560x1440 scale 1.25

# disable internal display on lid close
bindswitch --locked lid:on output $internal_screen disable
bindswitch --locked lid:off output $internal_screen enable

# keyboard
input * {
    xkb_layout "ee"
}

# touchpad
input type:touchpad {
		tap enabled
		natural_scroll enabled
		dwt enabled
}

# mod key
set $mod Mod4

# arrow keys
set $left h
set $down j
set $up k
set $right l

# bindings
bindsym $mod+Return exec alacritty
bindsym $mod+b exec firefox
bindsym $mod+Shift+b exec firefox --private-window
bindsym $mod+Space exec $launcher  
bindsym $mod+Shift+p exec $power

bindsym $mod+Shift+r exec ~/.config/sway/scripts/reload.sh
bindsym $mod+q kill

# move your focus around
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

# move the focused window with the same, but add Shift
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right

# switch to workspace
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

bindsym $mod+u splith
bindsym $mod+s splitv
bindsym $mod+f fullscreen
bindsym $mod+r mode "resize"

mode "resize" {
    bindsym $left resize shrink width 25px
    bindsym $down resize grow height 25px
    bindsym $up resize shrink height 25px
    bindsym $right resize grow width 25px

    # return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# mouse buttons
bindsym --whole-window button8 workspace next_on_output
bindsym --whole-window button9 workspace prev_on_output

# laptop buttons
bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+

# looks
default_border pixel 2
gaps outer 4
gaps inner 6
smart_gaps on
smart_borders on

# theme
include ~/.config/sway/theme
include ~/.config/sway/wallpaper

client.focused          $bar_focused_border $bar_focused_bg $bar_focused_fg $focused_indicator $focused_child_border
client.focused_inactive $bar_unfocused_border $bar_unfocused_bg $bar_unfocused_fg $unfocused_indicator $unfocused_child_border
client.unfocused        $bar_unfocused_border $bar_unfocused_bg $bar_unfocused_fg $unfocused_indicator $unfocused_child_border
client.urgent           $bar_urgent_border $bar_urgent_bg $bar_urgent_fg $urgent_indicator $urgent_child_border

bar {
    position top
    height 32
    workspace_min_width 32
    font "UbuntuNerd Font 13px"
    status_command ~/projects/swaystats/tmp/swaystats
		status_edge_padding 10
    colors {
			background $bar_bg
			statusline $bar_fg
			separator $bar_separator
			focused_background $bar_focused_bg
			focused_statusline $bar_focused_fg
			focused_separator $bar_focused_separator
			focused_workspace  $focused_workspace_border $focused_workspace_bg $focused_workspace_fg
			active_workspace  $active_workspace_border $active_workspace_bg $active_workspace_fg
			inactive_workspace $inactive_workspace_border $inactive_workspace_bg $inactive_workspace_fg
			urgent_workspace $urgent_workspace_border $urgent_workspace_bg $urgent_workspace_fg
			binding_mode $bar_binding_mode_border $bar_binding_mode_bg $bar_binding_mode_fg
    }
}

# lock & sleep
exec swayidle -w \
	timeout 600 'swaylock -f' \
	timeout 900 'swaymsg "output * power off"' \
	resume 'swaymsg "output * power on"'

# notifications
exec dunst
